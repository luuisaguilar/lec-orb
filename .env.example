# Required for local development, preview, and production
# Replace both values with your real Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional. Demo mode is only honored in local development.
# Preview and Production never activate demo mode.
NEXT_PUBLIC_DEMO_MODE=false

# Email (Resend) — required for invitation emails in staging/production
RESEND_API_KEY=re_xxxxxxxxxxxx

# App URL — used to build invitation links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Do not set NODE_ENV manually for Next.js or Vercel.
